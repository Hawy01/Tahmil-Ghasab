name: Build Ghasab APK

on:
  push:
    branches:
      - main
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: Set up Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: 'stable'

      - name: Accept Android Licenses
        run: yes | flutter doctor --android-licenses || true

      - name: Install Dependencies
        run: pip install flet yt-dlp google-genai

      - name: Download FFmpeg for Android
        run: |
          mkdir -p assets
          # تحميل FFmpeg من مصدر مستقر بديل (نسخة arm64)
          # استخدمنا -f لضمان عدم تحميل ملفات تالفة 404
          curl -Lf https://github.com/master-of-zen/FFmpeg-binaries/releases/download/n4.4.1/ffmpeg-n4.4.1-android-arm64-static.tar.gz -o ffmpeg.tar.gz
          
          # فك الضغط مباشرة داخل مجلد assets
          tar -xzf ffmpeg.tar.gz -C assets --strip-components=1
          chmod +x assets/ffmpeg
          echo "حجم ملف FFmpeg المحمل:" && ls -lh assets/ffmpeg

      - name: Inject Legacy Storage to Manifest
        run: |
          find . -name "AndroidManifest.xml" -exec sed -i 's/<application/<application android:requestLegacyExternalStorage="true"/g' {} +

      - name: Build APK
        run: yes | flet build apk

      - name: Send APK to Telegram
        run: |
          curl -v -F "chat_id=${{ secrets.TELEGRAM_CHAT_ID }}" \
               -F "document=@$(find build/apk/ -name "*.apk")" \
               -F "caption=🚀 تمت المهمة! تم بناء 'تحميل غصب' مع FFmpeg بنجاح." \
               https://api.telegram.org/bot${{ secrets.TELEGRAM_BOT_TOKEN }}/sendDocument
