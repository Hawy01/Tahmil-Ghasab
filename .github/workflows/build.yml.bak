name: Build Ghasab APK

on:
  push:
    branches:
      - main
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: Set up Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: 'stable'

      - name: Accept Android Licenses
        run: yes | flutter doctor --android-licenses || true

      - name: Install Dependencies
        run: |
          pip install flet yt-dlp google-genai

      - name: Download FFmpeg for Android
        run: |
          mkdir -p assets
          # تحميل FFmpeg من مصدر مستقر بديل [استنتاج]
          curl -L https://github.com/Bofung/ffmpeg-android-static/releases/download/v4.4/ffmpeg-v4.4-android-arm64.tar.gz -o ffmpeg.tar.gz
          
          # فك الضغط ونقل الملف التنفيذي لمجلد الأصول [استنتاج]
          tar -xzf ffmpeg.tar.gz -C assets --strip-components=1
          chmod +x assets/ffmpeg
          ls -lh assets/ # للتأكد من حجم الملف في السجلات

      - name: Inject Legacy Storage to Manifest
        run: |
          find . -name "AndroidManifest.xml" -exec sed -i 's/<application/<application android:requestLegacyExternalStorage="true"/g' {} +

      - name: Build APK
        run: yes | flet build apk

      - name: Send APK to Telegram
        run: |
          curl -v -F "chat_id=${{ secrets.TELEGRAM_CHAT_ID }}" \
               -F "document=@$(find build/apk/ -name "*.apk")" \
               -F "caption=🚀 تم تجاوز خطأ الـ 9 بايت وبناء 'تحميل غصب' بنجاح!" \
               https://api.telegram.org/bot${{ secrets.TELEGRAM_BOT_TOKEN }}/sendDocument
